# .env.example
# 이 파일은 GitHub에 올려도 된다.
# 실제 Key는 절대!!!!!!!!!! 입력하지 말 것. 예시 형식만 보여준다.

GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=yout_mistral_api_key_here
HUGGINGFACE_TOKEN=yout_hf_token_key_here(hf_로 시작)

# CORS 허용할 프론트엔드 도메인 리스트 (쉼표로 구분)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-service.onrender.com

#---------------------------------------------------------

# Gemini, Mistral 둘 다 안 될 경우, 가짜 응답
MOCK_MODE=false

#---------------------------------------------------------
# 기본 모델
LLM_MODEL=gemini-2.5-flash-lite

# 선택 가능한 예시
# LLM_MODEL=gemini-2.5-flash
# LLM_MODEL=mistral-small-latest

# LLM_MODEL=huggingface:모델제공자/모델이름
# LLM_MODEL=huggingface:meta-llama/Llama-3.2-3B-Instruct